{
  "name": "brd-creator",
  "displayName": "BRD Creator",
  "description": "Create comprehensive Business Requirements Documents using GitHub Copilot",
  "version": "0.1.0",
  "publisher": "your-publisher-name",
  "type": "module",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "business requirements",
    "brd",
    "documentation",
    "copilot",
    "agent"
  ],
  "activationEvents": [
    "onCommand:brd-creator.start",
    "onCommand:brd-creator.openPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "brd-creator.start",
        "title": "BRD Creator: Start New BRD"
      },
      {
        "command": "brd-creator.openPanel",
        "title": "BRD Creator: Open Dashboard"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "brd-creator",
          "title": "BRD Creator",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "brd-creator": [
        {
          "id": "brd-creator.dashboard",
          "name": "Dashboard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/brd-creator-extension.git"
  },
  "license": "MIT"
}
